# ── Nebius Token Factory (OpenAI-compatible) ──────────────────────────────
# Get a key at https://tokenfactory.nebius.com  (Settings → API keys)
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
NEBIUS_EMBED_MODEL=Qwen/Qwen3-Embedding-8B            # 4096-dim (only embedder on Nebius TF)
NEBIUS_LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct     # quality instruct model

# ── Pinecone ──────────────────────────────────────────────────────────────
# Get a key at https://app.pinecone.io  (API Keys)
PINECONE_API_KEY=
PINECONE_INDEX=rag-simulator
PINECONE_CLOUD=aws                # serverless spec
PINECONE_REGION=us-east-1         # free-tier serverless region
EMBED_DIM=4096                    # MUST equal embedding model dim (Qwen3-Embedding-8B=4096)
PINECONE_METRIC=dotproduct        # required for hybrid (dense+sparse)

# ── Corpus paths ──────────────────────────────────────────────────────────
TRANSCRIPTS_DIR=Input-Data/Transcripts
SLIDES_DIR=Input-Data/Slides

# ── Tunables ──────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=80
TOP_K=8
RERANK_TOP_N=4                    # Phase 2
SIMILARITY_CUTOFF=0.40            # tuned for hybrid α=0.7 (answerable≥0.494, unanswerable≤0.300)

# Hybrid retrieval
HYBRID_ALPHA=0.7                  # 1.0=dense only, 0.0=sparse only (0.7 ties dense, adds lexical recall)
