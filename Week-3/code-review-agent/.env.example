# Postgres (matches docker-compose.yml; host port 5433)
DATABASE_URL=postgresql://cra:cra@localhost:5433/code_review

# ── Nebius Token Factory (OpenAI-compatible) ──────────────────────────────
# Get a key at https://tokenfactory.nebius.com  (Settings → API keys)
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/

# Per-agent models (verify against the /v1/models catalog for your account)
MODEL_QUALITY=moonshotai/Kimi-K2.6
MODEL_SECURITY=deepseek-ai/DeepSeek-V3.2
MODEL_TEST_GAP=meta-llama/Llama-3.3-70B-Instruct
MODEL_CONSOLIDATE=Qwen/Qwen3-235B-A22B-Instruct-2507

# ── GitHub (needed in Phase 6 for posting comments) ───────────────────────
# PAT with `repo` scope for the account that owns the target repo
GITHUB_TOKEN=

# ── LangSmith tracing (optional) ──────────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=code-review-agent
